void setup() {
  Serial.begin(115200);

  pinMode(light1, OUTPUT);
  pinMode(light2, OUTPUT);
  pinMode(socket1, OUTPUT);

  // Active LOW: HIGH means OFF at startup
  digitalWrite(light1, OFF_STATE);
  digitalWrite(light2, OFF_STATE);
  digitalWrite(socket1, OFF_STATE);

  Serial.print("Connecting to ");
  Serial.println(ssid);

  Serial.println("Starting SmartHouse WiFi...");

  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);

  IPAddress IP = WiFi.softAPIP();

  Serial.println("SmartHouse WiFi started.");
  Serial.print("Connect to WiFi: ");
  Serial.println(ssid);
  Serial.print("Password: ");
  Serial.println(password);
  Serial.print("Open this address: http://");
  Serial.println(IP);

  Serial.println();
  Serial.println("WiFi connected.");
  Serial.print("IP address: ");
  Serial.println(WiFi.localIP());

  server.begin();
}

void loop() {
  WiFiClient client = server.available();

  if (client) {
    String request = "";

    while (client.connected()) {
      if (client.available()) {
        char c = client.read();
        request += c;

        if (c == '\n') {
          if (request.indexOf("GET /L1ON") >= 0) {
            light1State = true;
            digitalWrite(light1, ON_STATE);
          }

          if (request.indexOf("GET /L1OFF") >= 0) {
            light1State = false;
            digitalWrite(light1, OFF_STATE);
          }

          if (request.indexOf("GET /L2ON") >= 0) {
            light2State = true;
            digitalWrite(light2, ON_STATE);
          }

          if (request.indexOf("GET /L2OFF") >= 0) {
            light2State = false;
            digitalWrite(light2, OFF_STATE);
          }

          if (request.indexOf("GET /S1ON") >= 0) {
            socket1State = true;
            digitalWrite(socket1, ON_STATE);
          }

          if (request.indexOf("GET /S1OFF") >= 0) {
            socket1State = false;
            digitalWrite(socket1, OFF_STATE);
          }

          client.println("HTTP/1.1 200 OK");
          client.println("Content-type:text/html");
          client.println("Connection: close");
          client.println();

          client.print(makePage());

          client.println();
          break;
        }
      }
    }

    delay(1);
    client.stop();
  }
