<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Smart Home Panel</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(to bottom right, #0f172a, #1e293b);
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      position: relative;
      overflow: hidden;
    }

    /* --- TECH-THEMED SECURITY OVERLAY SCREEN --- */
    #security-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at center, #1e1b4b 0%, #090d16 100%);
      z-index: 1000;
      display: flex;
      justify-content: center;
      align-items: center;
      transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.5s;
    }

    /* Futuristic Grid Background Pattern */
    #security-overlay::before {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      background-image: 
        linear-gradient(rgba(56, 189, 248, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(56, 189, 248, 0.03) 1px, transparent 1px);
      background-size: 30px 30px;
      background-position: center;
      pointer-events: none;
    }

    .login-box {
      background: rgba(15, 23, 42, 0.8);
      border: 1px solid #0284c7;
      padding: 40px;
      border-radius: 16px;
      text-align: center;
      box-shadow: 0 0 30px rgba(14, 165, 233, 0.2), inset 0 0 15px rgba(14, 165, 233, 0.1);
      width: 90%;
      max-width: 400px;
      backdrop-filter: blur(12px);
      position: relative;
      transition: transform 0.4s ease, opacity 0.4s ease;
    }

    /* Interactive UI status markers */
    .login-box::transparent-corner {
      content: "";
      position: absolute;
      width: 12px;
      height: 12px;
      border: 2px solid #38bdf8;
    }

    .login-box h2 {
      margin-top: 0;
      font-size: 1.8rem;
      margin-bottom: 8px;
      color: #38bdf8;
      letter-spacing: 1px;
      text-transform: uppercase;
      text-shadow: 0 0 10px rgba(56, 189, 248, 0.5);
    }

    .login-box p {
      color: #64748b;
      font-size: 0.85rem;
      margin-bottom: 30px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Secure Password Wrapper Elements */
    .password-container {
      position: relative;
      width: 100%;
      margin-bottom: 5px;
    }

    .login-box input[type="password"], 
    .login-box input[type="text"] {
      width: 100%;
      padding: 14px 45px 14px 14px;
      box-sizing: border-box;
      border: 1px solid #1e293b;
      border-left: 3px solid #0284c7;
      border-radius: 6px;
      background: #0b0f19;
      color: #f8fafc;
      font-size: 1rem;
      outline: none;
      font-family: monospace;
      letter-spacing: 2px;
      transition: all 0.2s ease;
    }

    .login-box input:focus {
      border-color: #38bdf8;
      box-shadow: 0 0 10px rgba(56, 189, 248, 0.25);
    }

    /* Interactive CSS Eye Icon Toggle Container */
    .eye-toggle {
      position: absolute;
      right: 15px;
      top: 50%;
      transform: translateY(-50%);
      width: 20px;
      height: 12px;
      border: 2px solid #64748b;
      border-radius: 50% 50%;
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
      transition: border-color 0.2s;
    }

    .eye-toggle::before {
      content: "";
      width: 6px;
      height: 6px;
      background: #64748b;
      border-radius: 50%;
    }

    .eye-toggle.visible {
      border-color: #38bdf8;
    }
    .eye-toggle.visible::before {
      background: #38bdf8;
    }

    /* Caps Lock Alert Banner Indicator */
    .caps-indicator {
      color: #f59e0b;
      font-size: 0.75rem;
      text-align: left;
      padding-left: 2px;
      margin-bottom: 12px;
      height: 16px;
      font-weight: bold;
      letter-spacing: 0.5px;
      visibility: hidden;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .login-box .error-msg {
      color: #ef4444;
      font-size: 0.85rem;
      margin-bottom: 20px;
      height: 18px;
      visibility: hidden;
      font-weight: bold;
    }

    /* Animated Action Controls */
    .btn-submit {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 6px;
      background: #0284c7;
      color: white;
      font-size: 1rem;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 1px;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(2, 132, 199, 0.3);
    }

    .btn-submit:hover {
      background: #0369a1;
      box-shadow: 0 4px 20px rgba(56, 189, 248, 0.5);
    }

    /* Sign-in Processing State Animation classes */
    .btn-submit.loading {
      background: #0f172a;
      color: #38bdf8;
      border: 1px dashed #38bdf8;
      cursor: not-allowed;
    }

    /* --- CORE APPLIANCE GRID CONTAINER --- */
    .container {
      text-align: center;
      background: rgba(255, 255, 255, 0.05);
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.4);
      width: 90%;
      max-width: 850px;
    }

    h1 {
      margin-bottom: 30px;
      font-size: 2.5rem;
    }

    .bulb-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 30px;
    }

    .bulb-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255, 255, 255, 0.05);
      padding: 20px;
      border-radius: 16px;
      transition: transform 0.2s ease, border-color 0.2s;
    }

    .bulb-card:hover {
      transform: translateY(-5px);
      border-color: rgba(56, 189, 248, 0.2);
    }

    .appliance {
      width: 90px;
      height: 90px;
      margin: 0 auto 20px;
      border-radius: 50%;
      background: #1e293b;
      box-shadow: inset 0 0 10px rgba(0,0,0,0.6);
      transition: all 0.3s ease;
      position: relative;
    }

    .bulb::after {
      content: "";
      width: 35px;
      height: 20px;
      background: #64748b;
      position: absolute;
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0 0 8px 8px;
    }

    .bulb.on {
      background: #fde047;
      box-shadow: 0 0 25px #fde047, 0 0 50px #facc15;
    }

    .socket::before, .socket::after {
      content: "";
      position: absolute;
      background: #0f172a;
      border-radius: 2px;
      transition: background 0.3s ease;
    }

    .socket::before { width: 8px; height: 22px; top: 34px; left: 28px; }
    .socket::after { width: 8px; height: 22px; top: 34px; right: 28px; }

    .socket-ground {
      position: absolute;
      width: 10px;
      height: 10px;
      background: #0f172a;
      border-radius: 50%;
      top: 15px;
      left: 50%;
      transform: translateX(-50%);
      transition: background 0.3s ease;
    }

    .socket.on {
      background: #38bdf8;
      box-shadow: 0 0 25px #06b6d4, 0 0 50px #3b82f6;
    }

    .socket.on::before, .socket.on::after, .socket.on .socket-ground {
      background: #090d16;
    }

    .btn-toggle {
      padding: 12px 20px;
      border: none;
      border-radius: 10px;
      background: #1e293b;
      border: 1px solid #334155;
      color: white;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .btn-toggle:hover {
      background: #2563eb;
      border-color: #3b82f6;
      box-shadow: 0 0 10px rgba(37, 99, 235, 0.4);
    }

    .status {
      margin-top: 12px;
      font-size: 0.95rem;
      color: #94a3b8;
    }
  </style>
</head>
<body>

  <div id="security-overlay">
    <div class="login-box" id="login-container">
      <h2>LOGIN</h2>
      <p>Smart Home Secuirty</p>
      
      <div class="password-container">
        <input type="password" id="password-input" placeholder="ACCESS KEY" onkeypress="handleKeyPress(event)" onkeyup="checkCaps(event)">
        <div class="eye-toggle" id="eye-icon" onclick="togglePasswordVisibility()"></div>
      </div>
      
      <div class="caps-indicator" id="caps-warning">CAPS lock is On</div>
      <div class="error-msg" id="error-message">Access Denied.</div>
      
      <button class="btn-submit" id="submit-btn" onclick="processSignIn()">Sign In</button>
    </div>
  </div>

  <div class="container">
    <h1>💡 Smart Home Control Panel</h1>

    <div class="bulb-grid">
      <div class="bulb-card">
        <div class="appliance bulb" id="bulb1"></div>
        <button class="btn-toggle" onclick="toggleDevice('bulb1', 'status1')">Bulb 1</button>
        <div class="status" id="status1">Status: OFF</div>
      </div>

      <div class="bulb-card">
        <div class="appliance bulb" id="bulb2"></div>
        <button class="btn-toggle" onclick="toggleDevice('bulb2', 'status2')">Bulb 2</button>
        <div class="status" id="status2">Status: OFF</div>
      </div>

      <div class="bulb-card">
        <div class="appliance socket" id="socket1">
          <div class="socket-ground"></div>
        </div>
        <button class="btn-toggle" onclick="toggleDevice('socket1', 'status3')">Socket</button>
        <div class="status" id="status3">Status: OFF</div>
      </div>
    </div>
  </div>

  <script>
  const gateway = `ws://192.168.X.X/ws`; 
  let websocket;
  let isAuthorized = false;

  // Track and Warn on Caps Lock engagement dynamically
  function checkCaps(event) {
    const capsWarning = document.getElementById('caps-warning');
    if (event.getModifierState && event.getModifierState('CapsLock')) {
      capsWarning.style.visibility = 'visible';
    } else {
      capsWarning.style.visibility = 'hidden';
    }
  }

  // Toggle visible attribute string mapping for raw input data
  function togglePasswordVisibility() {
    const passwordInput = document.getElementById('password-input');
    const eyeIcon = document.getElementById('eye-icon');
    
    if (passwordInput.type === 'password') {
      passwordInput.type = 'text';
      eyeIcon.classList.add('visible');
    } else {
      passwordInput.type = 'password';
      eyeIcon.classList.remove('visible');
    }
  }

  // Handle the Animated Sign In Process sequence
  function processSignIn() {
    const passwordInput = document.getElementById('password-input').value;
    const errorMsg = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');
    const overlay = document.getElementById('security-overlay');
    const loginContainer = document.getElementById('login-container');

    if (submitBtn.classList.contains('loading')) return;

    // Trigger UI loading state change on validation loop trigger
    submitBtn.textContent = "Verifying Key...";
    submitBtn.classList.add('loading');
    errorMsg.style.visibility = 'hidden';

    // Simulate short technical verification latency delay window (600ms)
    setTimeout(() => {
      if (passwordInput === 'Group16@2026') {
        isAuthorized = true;
        submitBtn.textContent = "Access Granted";
        submitBtn.style.background = "#10b981";
        submitBtn.style.color = "#ffffff";
        
        // Execute clean out transition styles
        loginContainer.style.transform = "scale(0.9)";
        loginContainer.style.opacity = "0";
        overlay.style.opacity = '0';
        
        setTimeout(() => {
          overlay.style.visibility = 'hidden';
        }, 500);

        initWebSocket();
      } else {
        isAuthorized = false;
        submitBtn.textContent = "Sign In";
        submitBtn.classList.remove('loading');
        errorMsg.style.visibility = 'visible';
        document.getElementById('password-input').value = '';
      }
    }, 600);
  }

  function handleKeyPress(event) {
    if (event.key === 'Enter') {
      processSignIn();
    }
  }

  function initWebSocket() {
    if (!isAuthorized) return;
    
    console.log('Opening WebSocket Link Layer...');
    websocket = new WebSocket(gateway);
    
    websocket.onopen = () => console.log('Connected to ESP32 Platform Server Module');
    websocket.onclose = () => {
      if (isAuthorized) {
        console.log('Link connection lost. Re-polling stream path...');
        setTimeout(initWebSocket, 2000);
      }
    };
  }

  function toggleDevice(deviceId, statusId) {
    if (!isAuthorized) {
      alert("System Core Lockout Active.");
      return;
    }

    const device = document.getElementById(deviceId);
    const status = document.getElementById(statusId);

    device.classList.toggle('on');
    const isOn = device.classList.contains('on');

    status.textContent = isOn ? 'Status: ON' : 'Status: OFF';

    if (websocket && websocket.readyState === WebSocket.OPEN) {
        const signal = `${deviceId.toUpperCase()}_${isOn ? 'ON' : 'OFF'}`;
        websocket.send(signal);
        console.log("Transmission payload fired:", signal);
    }
  }
  </script>
</body>
</html>
